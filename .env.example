# =============================================================================
# PotagerAI — Variables d'environnement
# IMPORTANT : Copier ce fichier en .env et remplir les valeurs
#             Ne jamais committer .env sur Git
# =============================================================================

# --- Base de données PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/potagerai
DB_USER=potagerai_user
DB_PASS=potagerai_pass

# --- JWT (OBLIGATOIRE en production : minimum 32 caractères aléatoires) ---
# Générer avec : openssl rand -base64 48
JWT_SECRET=REMPLACER_PAR_UNE_CLE_ALEATOIRE_DE_48_CARACTERES_MINIMUM

# --- CORS Frontend ---
FRONTEND_URL=http://localhost:4200
